# --- LLM (LiteLLM-style) ---
# Any LiteLLM-supported model string works:
#   openai/<model>, anthropic/<model>, ollama/<model>, ...
PRAP_LLM_MODEL=openai/gpt-4o-mini
PRAP_LLM_API_KEY=
PRAP_LLM_API_BASE=
PRAP_LLM_API_VERSION=

# --- OCR ---
# One of: unstructured, tesseract
PRAP_OCR_BACKEND=unstructured

# --- Cache ---
# Directory for the on-disk LLM response cache. Default lives outside the repo.
PRAP_CACHE_DIR=~/.cache/prap
